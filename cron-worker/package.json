{
  "name": "paper-boy-cron",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker that triggers paper-boy build/deliver via GitHub repository_dispatch",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
